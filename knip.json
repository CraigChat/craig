{
  "entry": [
    "*.js",
    "scripts/*.ts",
    "cook/**/*.js",
    "tests/**/*.js"
  ],
  "workspaces": {
    "apps/bot": {
      "entry": [
        "src/index.ts",
        "src/commands/*.ts",
        "src/textCommands/*.ts",
        "src/sharding/index.ts",
        "src/sharding/modules/*.ts",
        "slash-up.config.js"
      ]
    },
    "apps/dashboard": {
      "entry": ["pages/**/*.{ts,tsx}"]
    },
    "apps/download": {
      "entry": ["api/src/index.ts", "page/src/index.tsx"]
    },
    "apps/tasks": {
      "entry": ["src/index.ts", "src/jobs/*.ts", "src/runJob.ts"]
    }
  }
}
