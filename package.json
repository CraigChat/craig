{
  "name": "craig",
  "version": "0.0.0",
  "homepage": "http://craig.chat/",
  "license": "ISC",
  "private": true,
  "author": {
    "name": "Snazzah",
    "email": "me@snazzah.com",
    "url": "https://snazzah.com/"
  },
  "engines": {
    "node": ">=22.15.0",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "turbo dev --no-daemon",
    "dev:no-bot": "turbo dev --no-daemon -F '!@craig/bot'",
    "inspect": "turbo inspect",
    "build": "git submodule update --init && turbo build",
    "lint": "turbo lint",
    "format": "turbo format",
    "build-cook": "pnpm -F kitchen -F ennuizel-streamer run build-cook",
    "sync": "pnpm -F bot run sync",
    "sync:dev": "pnpm -F bot run sync:dev",
    "db:deploy": "dotenv -c -- pnpm -F db run db:migrate:deploy",
    "db:push": "dotenv -c -- pnpm -F db run db:push",
    "db:migrate:dev": "dotenv -c -- pnpm -F db run db:migrate:dev",
    "prisma": "dotenv -c -- pnpm -F db run prisma",
    "run-task": "pnpm -F tasks run-task",
    "entitlement": "dotenv -c -- tsx scripts/manageEntitlements.mts",
    "ctl": "pnpm -F botctl cli",
    "bot-instance": "pnpm -F bot instance"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CraigChat/craig"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@craig/db": "workspace:*",
    "dotenv-cli": "8.0.0",
    "eslint": "10.0.2",
    "eslint-config-craig": "workspace:*",
    "rimraf": "5.0.10",
    "tsdown": "0.20.3",
    "tsx": "^4.21.0",
    "turbo": "2.8.11"
  },
  "devDependencies": {
    "@types/node": "^22.15.21"
  }
}
