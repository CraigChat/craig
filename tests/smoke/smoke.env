# Smoke-test environment — placeholder values only, never real secrets.
# Used by CI: cp tests/smoke/smoke.env .env.smoke

# PostgreSQL
POSTGRES_USER=craig
POSTGRES_PASSWORD=craig
POSTGRES_DB=craig
POSTGRESQL_USER=craig
POSTGRESQL_PASSWORD=craig
DATABASE_NAME=craig
DATABASE_URL=postgresql://craig:craig@db:5432/craig?schema=public
POSTGRESQL_START_TIMEOUT_S=10

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_START_TIMEOUT_S=10

# Recordings directory (created by CI before compose up)
CRAIG_RECORDINGS_DIR=/tmp/smoke-rec

# Download service
API_PORT=5029
API_HOST=0.0.0.0
DOWNLOADS_PATH=/app/downloads
ENNUIZEL_BASE=https://ez.craig.horse/
TRUST_PROXY=
RECORDING_RETENTION_DAYS=3
SERVER_NAME=smoke
API_HOMEPAGE=http://localhost:5029

# Dashboard
CLIENT_ID=000000000000000000
CLIENT_SECRET=smoke-placeholder
JWT_SECRET=smoke-placeholder
APP_URI=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=smoke-placeholder

# OAuth providers (disabled in smoke)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=

# Bot (not started in smoke, but env_file is still parsed by migrate)
DISCORD_BOT_TOKEN=smoke-placeholder
DISCORD_APP_ID=000000000000000000
CRAIG_INTERNAL_SECRET=smoke-placeholder
CRAIG_INTERNAL_PORT=3001
TASKS_URL=http://tasks:2022
NODE_VERSION=22

# AI/summarization (not started in smoke)
NVIDIA_API_KEY=
OPENROUTER_API_KEY=
