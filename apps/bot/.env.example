BOT_TOKEN=
BOT_APPLICATION_ID=

# Optional. Defaults to Discord's Get Gateway Bot recommendation.
BOT_SHARD_COUNT=
BOT_SHARD_CONCURRENCY=
BOT_WORKER_FILE=./dist/index.mjs
BOT_READY_TIMEOUT=60000

# Source assets. Defaults are relative to apps/bot when using package scripts.
BOT_ASSET_ROOT=./assets
BOT_EMOJI_FOLDER=./emojis
BOT_VOICE_TEST_FOLDER=./assets/audio
BOT_LOCALE_FOLDER=../../locale

BOT_CONTROL_HOST=127.0.0.1
BOT_CONTROL_PORT=9200
# Required if BOT_CONTROL_HOST is not localhost/127.0.0.1/::1.
BOT_CONTROL_TOKEN=
BOT_CONTROL_ALLOW_EVAL=false

METRICS_PORT=9201
KITCHEN_URL=http://127.0.0.1:9000

DOWNLOAD_PROTOCOL=http
DOWNLOAD_DOMAIN=localhost:5029
DASHBOARD_URL=https://my.craig.chat
CRAIG_HOMEPAGE=https://craig.chat/
INVITE_CLIENT_ID=
SYSTEM_NOTIFICATION_URL=

NOW_RECORDING_OPUS=
# REC_DIRECTORY=

CRAIG_EMOJI_ID=297187944295301122
SIZE_LIMIT=536870912
SIZE_LIMIT_WEB=4294967296
SIZE_LIMIT_WEB_OPUS=1073741824

WEBAPP_ENABLED=true
WEBAPP_URL=ws://127.0.0.1:9001/shard
WEBAPP_TOKEN=
WEBAPP_CONNECT_URL=http://localhost:5000?id={id}&key={key}

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PREFIX=craig:

ELEVATED_USERS=
LOGGER_LEVEL=debug

# JSON object keyed by tier number. Defaults are built in if unset.
REWARD_TIERS_JSON=

SENTRY_DSN=
SENTRY_ENV=
SENTRY_SAMPLE_RATE=1
