{
  "name": "@craig/bot",
  "version": "1.0.0",
  "description": "Craig Discord bot",
  "private": true,
  "type": "module",
  "main": "dist/index.mjs",
  "license": "MIT",
  "scripts": {
    "start": "dotenv -e ../../.env -e .env -c -- node dist/index.mjs",
    "start:sharding": "dotenv -e ../../.env -e .env -c -- node dist/sharding/index.mjs",
    "start-pm2": "dotenv -e ../../.env -e .env -c -- pm2 start ecosystem.config.cjs",
    "reload-pm2": "dotenv -e ../../.env -e .env -c -- pm2 reload ecosystem.config.cjs --update-env",
    "build": "rimraf dist && tsdown",
    "dev": "dotenv -e ../../.env -e .env -c -- tsx src/index",
    "dev:sharding": "dotenv -e ../../.env -e .env -c -- tsx src/sharding/index",
    "sync": "dotenv -e ../../.env -e .env -c -- slash-up sync",
    "sync:dev": "dotenv -e ../../.env -e .env -c -- slash-up sync -e development",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "instance": "node scripts/instance.mjs"
  },
  "dependencies": {
    "@craig/common": "workspace:*",
    "@craig/db": "workspace:*",
    "@craig/logger": "workspace:*",
    "@craig/metrics": "workspace:*",
    "@discordjs/opus": "^0.10.0",
    "@projectdysnomia/dysnomia": "github:projectdysnomia/dysnomia#de437ad5b6230b62a9594bafc951fff3a1f6d6c8",
    "@sentry/integrations": "^7.120.4",
    "@sentry/node": "^7.120.4",
    "@sentry/tracing": "^7.120.4",
    "@snazzah/davey": "^0.1.10",
    "@snazzah/emoji-sync": "^0.1.2",
    "axios": "^1.13.2",
    "common-tags": "^1.8.2",
    "cron": "^4.3.4",
    "dotenv": "^16.6.1",
    "fastify": "^4.29.1",
    "fastq": "^1.19.1",
    "i18next": "^25.7.2",
    "i18next-fs-backend": "^2.6.1",
    "ioredis": "^5.8.2",
    "nanoid": "^3.3.11",
    "node-fetch": "2.7.0",
    "semver": "^7.7.3",
    "slash-create": "^6.8.1",
    "sodium-native": "^5.1.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/common-tags": "^1.8.4",
    "@types/node": "^22.15.21",
    "@types/node-fetch": "^2.6.13",
    "@types/semver": "^7.7.1",
    "@types/ws": "^8.18.1",
    "slash-up": "^1.2.0",
    "tsdown": "0.21.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "undici-types": "^7.16.0"
  }
}
