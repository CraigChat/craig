###################################################
# Discord bot
###################################################

DISCORD_BOT_TOKEN=
DISCORD_APP_ID=
CLIENT_ID=
CLIENT_SECRET=
DEVELOPMENT_GUILD_ID=

##################################################
# Dashboard app environment
##################################################

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DRIVE_FOLDER_PATH=Folder/recordings
MICROSOFT_CLIENT_ID=test
MICROSOFT_CLIENT_SECRET=test
DROPBOX_CLIENT_ID=test
DROPBOX_CLIENT_SECRET=test
APP_URI=https://craigboard.home.arpa
JWT_SECRET=change-me-generate-a-long-random-value

##################################################
# Download app environment
##################################################

API_PORT=5029
API_HOST=0.0.0.0
API_HOMEPAGE=https://craig.home.arpa
ENNUIZEL_BASE=https://ez.craig.horse/
TRUST_PROXY=
SENTRY_DSN=
SENTRY_HOST=
SENTRY_SAMPLE_RATE=1.0
SENTRY_DSN_API=
SENTRY_ENV=
SENTRY_SAMPLE_RATE_API=1.0
INFLUX_URL=
INFLUX_TOKEN=
INFLUX_ORG=
INFLUX_BUCKET=
SERVER_NAME=dev
REDIS_HOST=redis
REDIS_PORT=6379
RECORDING_RETENTION_DAYS=3

##################################################
# TASMAS transcription sidecar
##################################################

CRAIG_RECORDINGS_DIR=/mnt/media8tb/craig-recordings
TASMAS_OUTPUT_DIR=/mnt/media8tb/craig-recordings/tasmas
TASMAS_IMAGE=kaddaok/tasmas:latest
TASMAS_GPU_ARGS="--gpus all"
TASMAS_MODEL_CACHE_DIR=/mnt/media8tb/craig-recordings/tasmas-model-cache
TASMAS_EXTRA_ARGS=
TASMAS_WATCH_INTERVAL=10
TASMAS_SETTLE_SECONDS=5
TASMAS_RECORDINGS_LOCK_FILE=recordings.lock.json

##################################################
# AI Summary
##################################################

# Primary summarization provider (NVIDIA NIM or any OpenAI-compatible endpoint)
NVIDIA_API_KEY=
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/chat/completions

# Model and generation params applied to all providers (AI_SUMMARY_* preferred; NVIDIA_SUMMARY_* accepted as aliases)
AI_SUMMARY_MODEL=mistralai/mistral-large-3-675b-instruct-2512
AI_SUMMARY_MAX_TOKENS=2048
AI_SUMMARY_TEMPERATURE=0.15
AI_SUMMARY_TOP_P=1.0
AI_SUMMARY_FREQUENCY_PENALTY=0.0
AI_SUMMARY_PRESENCE_PENALTY=0.0

# OpenRouter credentials (independent infra, used as fallback)
OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions

# Fallback chain: semicolon-separated entries of url|API_KEY_ENV_VAR|model
# Tried in order after the primary (NVIDIA_API_KEY) fails. Leave empty to disable.
SUMMARY_FALLBACK_CHAIN=https://integrate.api.nvidia.com/v1/chat/completions|NVIDIA_API_KEY|mistralai/mistral-small-3.1-24b-instruct;https://openrouter.ai/api/v1/chat/completions|OPENROUTER_API_KEY|mistralai/mistral-small-3.1-24b-instruct:free

# Seconds to wait before each fallback attempt
SUMMARY_RETRY_DELAY_SECONDS=120

##################################################
# Internal API — per-guild summary routing
##################################################

# Secret shared between TASMAS and the bot (generate a random value)
CRAIG_INTERNAL_PORT=3001
CRAIG_INTERNAL_SECRET=change-me-generate-a-random-value
# Used by TASMAS to notify the bot:
CRAIG_INTERNAL_API_URL=http://craig:3001/deliver-summary
# Used by the bot (path to TASMAS output dir from inside the craig container):

##################################################
# DATABASE
##################################################

NODE_VERSION="22"
DATABASE_NAME="craig"
POSTGRESQL_USER="craig"
POSTGRESQL_PASSWORD="change-me"
POSTGRES_DB="craig"
POSTGRES_USER="craig"
POSTGRES_PASSWORD="change-me"
POSTGRESQL_START_TIMEOUT_S=10
DATABASE_URL=postgresql://$POSTGRESQL_USER:$POSTGRESQL_PASSWORD@db:5432/$DATABASE_NAME?schema=public
REDIS_START_TIMEOUT_S=10
