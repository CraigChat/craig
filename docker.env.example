# Craig Docker self-host configuration
# Copy this file to docker.env and edit the required values before starting Compose.

### Docker image and published ports
CRAIG_IMAGE_TAG=latest
CRAIG_VERSION=local
CRAIG_DASHBOARD_HOST_PORT=9200
CRAIG_FERRET_HOST_PORT=9100
CRAIG_ENNUIZEL_HOST_PORT=9001
CRAIG_STARTUP_TIMEOUT=90
CRAIG_SKIP_MIGRATIONS=false

### Postgres
# POSTGRES_PASSWORD should be URL-safe because docker-compose.yml builds DATABASE_URL from it.
POSTGRES_USER=craig
POSTGRES_PASSWORD=change-me
POSTGRES_DB=craig

### Redis
REDIS_DATABASE=0
REDIS_PREFIX=craig:

### Required Discord bot values
BOT_TOKEN=
BOT_APPLICATION_ID=
PUBLIC_DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:9200/api/login
JWT_SECRET=change-me-to-at-least-32-random-characters

### Public URLs
DASHBOARD_URL=http://localhost:9200
PUBLIC_BASE_URL=http://localhost:9200
ORIGIN=http://localhost:9200
DOWNLOAD_PROTOCOL=http
DOWNLOAD_DOMAIN=localhost:9100
CRAIG_HOMEPAGE=http://localhost:9200
WEBAPP_CONNECT_URL=http://localhost:9001?id={id}&key={key}
PUBLIC_ENNUIZEL_URL=http://localhost:9001
PUBLIC_ENNUIZEL_API_HOSTNAME=localhost:9001
PUBLIC_HOSTNAME=localhost

### Storage paths inside the container
# docker-compose.yml mounts ./rec, ./downloads, ./output, and ./tmp to these paths.
REC_DIRECTORY=/data/rec
DOWNLOADS_DIRECTORY=/data/downloads
OUTPUT_DIRECTORY=/data/output
TMP_DIRECTORY=/data/tmp

### Bot behavior
BOT_STATUS_TEXT=Recording VCs
BOT_SHARD_COUNT=
BOT_SHARD_CONCURRENCY=
BOT_READY_TIMEOUT=60000
BOT_RESPAWN=true
BOT_CONTROL_HOST=127.0.0.1
# BOT_CONTROL_PORT=9300
# BOT_CONTROL_TOKEN=
BOT_CONTROL_ALLOW_EVAL=false
BOT_CONTROL_ALLOWED_CIDRS=
BOT_CONTROL_TRUST_HEADER=
ELEVATED_USERS=
DEVELOPMENT_GUILD_ID=
INVITE_CLIENT_ID=
SYSTEM_NOTIFICATION_URL=
VOICE_OBSERVATORY_TOKEN=
LOGGER_LEVEL=debug

### Bot limits and rewards
CRAIG_EMOJI_ID=297187944295301122
SIZE_LIMIT=536870912
SIZE_LIMIT_WEB=4294967296
SIZE_LIMIT_WEB_OPUS=1073741824
# REWARD_TIERS_JSON=
# SUPPORTER_MINIMUM_TIER=

### Live web app
WEBAPP_ENABLED=true
WEBAPP_TOKEN=

### Dashboard optional integrations
PUBLIC_PLAUSIBLE_HOSTNAME=
PUBLIC_CRAIG_ENV=
PUBLIC_PATREON_URL=CraigRec
PUBLIC_PATREON_CLIENT_ID=
PATREON_CLIENT_SECRET=
PATREON_WEBHOOK_SECRET=
PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
PUBLIC_MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CLIENT_REDIRECT=
PUBLIC_DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=
DROPBOX_FOLDER_NAME=
PUBLIC_BOX_CLIENT_ID=
BOX_CLIENT_SECRET=

### Ferret
PUBLIC_STATUS_SITE=
PUBLIC_TEST_RECORDINGS=
PUBLIC_AVATAR_CDN=

### Kitchen
UNIQUE_KITCHEN_ID=primary
AVATAR_CDN=
JOB_EXPIRATION=1d
TMP_EXPIRATION=6h
KITCHEN_CRON_TIME="0 * * * *"
SAVE_JOBS=true
KITCHEN_CLEAN_FILES=true
QUEUE_SIZE=
PROC_NICENESS=10
PROC_TASKSET_CPU_MAP=
PROC_IONICE=3
PROC_CHRT_IDLE=true
RUNPOD_TRANSCRIPTION_ENDPOINT_ID=
RUNPOD_API_KEY=
DOWNLOAD_URL_PREFIX=

### Ennuizel streamer
PROXY_HEADER=
SNAPSHOT_KEY=

### Scheduled tasks
PATREON_REFRESH_CRON="0 * * * *"
RECORDING_CLEAN_CRON="*/30 * * * *"
TASKS_TIMEZONE=America/New_York
TASKS_IGNORE=
PATREON_CAMPAIGN_ID=
PATREON_CLIENT_ID=
PATREON_CLIENT_SECRET=
PATREON_TIER_MAP={}
PATREON_CREDENTIALS_FILE=
RECORDING_FALLBACK_EXPIRATION=24h
RECORDING_SKIP_IDS=
RECORDING_SKIP_ALL=false

### Sentry
SENTRY_DSN=
SENTRY_ENV=
SENTRY_SAMPLE_RATE=1
